# Anthropic
ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key

# SIFT VM connection
SIFT_HOST=192.168.56.101
SIFT_PORT=22
SIFT_USER=sansforensics
SIFT_SSH_KEY_PATH=~/.ssh/sift_id_rsa

# ForensIQ backend
FORENSICIQ_HOST=0.0.0.0
FORENSICIQ_PORT=8000
